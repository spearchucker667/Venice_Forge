# Venice API
# IMPORTANT: leave the value empty. The previous `replace_with_your_venice_inference_key`
# placeholder was copied verbatim by some users, which sent a bogus bearer token
# to the upstream API and produced confusing 401s. An empty value forces the
# first-run setup wizard to prompt for a real key.
VENICE_API_KEY=""

# Jina API
# Used for web search and scraping integrations in Research Workspace.
# Leave empty unless you run the proxy standalone; otherwise, the desktop app
# will prompt you for this key and store it securely.
JINA_API_KEY=""

# Server
PORT=3000
HOST=127.0.0.1

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# Proxy
MAX_PROXY_BODY_BYTES=26214400
TRUST_PROXY=

# Upstream API (override for testing against staging or mirrors)
# VENICE_API_HOST=api.venice.ai
# VENICE_API_BASE_PATH=/api/v1
# VENICE_API_TIMEOUT_MS=60000
# VENICE_TIMEOUT_MS=60000  # Deprecated alias for VENICE_API_TIMEOUT_MS — still accepted as fallback

# Development
NODE_ENV=development
DISABLE_HMR=false
# ELECTRON_BUILD=true  # Set automatically by build:web; triggers stripCrossorigin plugin and sets base: "./"

# Security
# Allow plaintext key storage fallback when OS secure storage is unavailable (Linux/non-GNOME).
# WARNING: This stores your encryption key in plaintext and reduces security.
# VENICE_FORGE_ALLOW_PLAINTEXT_KEY_STORAGE=false

# Allow DevTools in packaged production builds. Only enable for debugging.
# VENICE_FORGE_DEBUG_DEVTOOLS=false

# Local master YAML config override paths. If set, these absolute paths are
# used in place of the canonical repo-local / userData locations.
# VENICE_FORGE_CONFIG_FILE=/absolute/path/to/config.yaml
# VENICE_FORGE_THEMES_FILE=/absolute/path/to/themes.yaml

# Family Safe Mode and Venice API Safe Mode are persisted app/YAML settings,
# not environment bypasses. See docs/CONFIG.md under `safety:`.
#
# Server-side override for the web proxy's Local Family Safe Mode.
# When set, the proxy ignores the renderer-supplied header and uses this
# value as the authoritative setting, preventing malicious clients from
# bypassing the safety guard. Defaults to ON (true) when unset.
VENICE_FORGE_LOCAL_FAMILY_SAFE_MODE_ENABLED=true
