# Optional: override the Venice API base URL.
# - Leave blank in dev to use the Vite proxy (vite.config.ts).
# - In prod, defaults to https://api.venice.ai/api/v1 (CORS must allow your origin).
# - For self-hosted proxies, set this to your proxy's /api/v1 base.
# VITE_VENICE_BASE_URL=https://api.venice.ai/api/v1
