# =============================================================================
# Dependencies and local runtimes
# =============================================================================
/node_modules/
/.node22/
# =============================================================================
# Generated build, test, and release output
# =============================================================================
/dist/
/dist-electron/
/release/
/coverage/
/.vite/
# =============================================================================
# Generated design captures and development-tool output
# =============================================================================
/.design-captures/
/.impeccable/
/scripts/dev-tools/venice-styles.json
# =============================================================================
# Build resources
#
# Ignore generated build assets while retaining canonical packaging icons.
# =============================================================================
/build/*
!/build/icon.ico
!/build/icon.icns
!/build/icon.png
!/build/icon-placeholder.md
# =============================================================================
# Local agent handoffs and generated documentation
# =============================================================================
/docs/AGENTS/
/docs/HQE_AUDIT_REPORT.md
# Local privacy summaries generated by agents.
/docs/AGENTS/venice-forge-privacy-summary-*.json
# =============================================================================
# Design-roadmap scratchpads
#
# Theme tokens are canonical in src/styles/theme.css. Markdown design notes may
# remain tracked.
# =============================================================================
/docs/design/*
!/docs/design/*.md
# =============================================================================
# Local audit and cross-reference scratchpads
#
# The canonical work record lives in docs/summary_of_work.md.
# =============================================================================
/todo.md
/records.json
/records*.json
/work done*.md
/*work*done*.md
/*session*.json
/*session*.md
/kimi-export-session_*.md
/*_ledger.py
/chat-history/
/docs_list.txt
/target_inventory.txt
/hashes.txt
/duplicate_hashes.txt
/duplicates.txt
# =============================================================================
# Audit artifacts
#
# Ignore audit output by default while retaining approved reports, manifests,
# structured evidence, and visual snapshots.
# =============================================================================
/docs/audits/*

# Keep Records and active directories
!/docs/audits/Records/
!/docs/audits/active/
# Retain supported top-level audit documents.
!/docs/audits/*.md
!/docs/audits/*.yaml
!/docs/audits/*.yml
# Local generated inventory files.
/docs/audits/file-inventory.tsv
/docs/audits/repo-tree-current.txt
# Venice Forge scan evidence — 2026-07-14.
!/docs/audits/VENICE_FORGE_SCAN_EVIDENCE_2026-07-14/
/docs/audits/VENICE_FORGE_SCAN_EVIDENCE_2026-07-14/*
!/docs/audits/VENICE_FORGE_SCAN_EVIDENCE_2026-07-14/*.md
!/docs/audits/VENICE_FORGE_SCAN_EVIDENCE_2026-07-14/*.json
# Approved visual regression snapshots.
!/docs/audits/visual-snapshots/
/docs/audits/visual-snapshots/*
!/docs/audits/visual-snapshots/*.png
# Generated audit directories outside docs/audits.
/Venice_Forge-audit-*/
/*-audit-*/

# =============================================================================
# Local configuration and secrets
# =============================================================================
.env*
!.env.example
/.config/*.local.yaml
/.config/*.local.yml
/.config/*.yaml
/.config/*.yml
!/.config/*.example.yaml
!/.config/*.example.yml
/.integration-src/
# =============================================================================
# Local scripts and scratch copies
# =============================================================================
# Ignore the root-level scratch copy. The canonical script is tracked under
# scripts/clean-repo-zip.sh.
/clean-repo-zip.sh
!/scripts/clean-repo-zip.sh
/scratch/
/.superpowers/
# =============================================================================
# Runtime logs and temporary files
# =============================================================================
/venice-forge.log
*.log
*.tmp
*.bak
# Upstream-agent transcript dumps are forensic artifacts, not source files.
/patch_*.txt
# =============================================================================
# Operating-system and editor metadata
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini
# =============================================================================
# Archive contaminants
#
# These files must never appear in ZIP, tarball, or release artifacts.
# =============================================================================
__MACOSX/
.AppleDouble/
._*
_REPO_EXTRACT_METADATA/
